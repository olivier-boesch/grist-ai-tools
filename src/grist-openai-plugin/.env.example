# Grist API key — Profile Settings > API key in the Grist UI
GRIST_API_KEY=

# Base URL of the Grist API. Defaults to Grist SaaS if unset.
# For self-hosted Grist, use e.g. https://grist.mycompany.com/api
GRIST_API_URL=https://docs.getgrist.com/api

# Secret bearer token that the Custom GPT must send in the
# "Authorization: Bearer <token>" header. Required so this server isn't
# an open proxy to your Grist account. Set the same value as the GPT
# Action's "API Key" authentication.
ACTION_API_KEY=
